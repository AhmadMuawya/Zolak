<Page x:Class="WaysToSnooze.Zolak.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI Variable, Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Margin="24,20">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">

            <!-- ═══════════════════════════════════════════════════════════
                 HEADER
                 ═══════════════════════════════════════════════════════════ -->
            <TextBlock Text="Settings"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Customize your Zolak desktop pet behavior and appearance."
                       FontSize="12" Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,24"/>

            <!-- ═══════════════════════════════════════════════════════════
                 CHARACTER SELECTION
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Character" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Select the active pet character."
                                       FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,2,0,0" TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <ComboBox x:Name="CharacterCombo" Grid.Column="1"
                                  Style="{DynamicResource VsComboBox}"
                                  Width="150" VerticalAlignment="Center"
                                  SelectionChanged="CharacterCombo_SelectionChanged"/>
                        <Button x:Name="AddCharBtn" Grid.Column="2"
                                Style="{DynamicResource VsGhostButton}"
                                Click="AddCharBtn_Click" Margin="6,0,0,0"
                                VerticalAlignment="Center" ToolTip="Add new character"
                                Padding="4">
                            <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="DeleteCharBtn" Grid.Column="3"
                                Style="{DynamicResource VsGhostButton}"
                                Click="DeleteCharBtn_Click" Margin="4,0,0,0"
                                VerticalAlignment="Center" ToolTip="Delete character"
                                Padding="4" Foreground="{DynamicResource DangerColor}"
                                Visibility="Collapsed">
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </Grid>
                    <!-- Inline name input (hidden by default) -->
                    <Grid x:Name="NewCharPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewCharNameBox" Grid.Column="0"
                                 Style="{DynamicResource VsTextBox}"
                                 FontSize="12" VerticalAlignment="Center"
                                 Tag="Enter character name..."/>
                        <Button x:Name="ConfirmCharBtn" Grid.Column="1"
                                Style="{DynamicResource VsButton}"
                                Content="Create" Padding="12,5"
                                Margin="6,0,0,0" Click="ConfirmChar_Click"/>
                        <Button Grid.Column="2"
                                Style="{DynamicResource VsGhostButton}"
                                Content="✕" Padding="6,5"
                                Margin="4,0,0,0" Click="CancelChar_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 PET SIZE
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Pet Size" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="PetSizeValueLabel"
                                   HorizontalAlignment="Right"
                                   FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                    </Grid>
                    <TextBlock Text="Scale the pet sprite size in pixels (32–192)."
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="PetSizeSlider" Grid.Column="0"
                                Style="{DynamicResource VsSlider}"
                                Minimum="32" Maximum="192"
                                TickFrequency="8" IsSnapToTickEnabled="True"
                                ValueChanged="PetSizeSlider_ValueChanged"/>
                        <TextBox x:Name="PetSizeTextBox" Grid.Column="1"
                                 Style="{DynamicResource VsTextBox}"
                                 Margin="8,0,0,0"
                                 HorizontalContentAlignment="Center"
                                 LostFocus="PetSizeTextBox_LostFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 ANIMATION SPEED
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Animation Speed" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="AnimSpeedValueLabel"
                                   HorizontalAlignment="Right"
                                   FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                    </Grid>
                    <TextBlock Text="Frame rate multiplier (0.5x = slow, 2.0x = fast)."
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="AnimSpeedSlider" Grid.Column="0"
                                Style="{DynamicResource VsSlider}"
                                Minimum="0.5" Maximum="3.0"
                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                ValueChanged="AnimSpeedSlider_ValueChanged"/>
                        <TextBox x:Name="AnimSpeedTextBox" Grid.Column="1"
                                 Style="{DynamicResource VsTextBox}"
                                 Margin="8,0,0,0"
                                 HorizontalContentAlignment="Center"
                                 LostFocus="AnimSpeedTextBox_LostFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 GRAVITY
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Gravity Strength" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="GravityValueLabel"
                                   HorizontalAlignment="Right"
                                   FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                    </Grid>
                    <TextBlock Text="Physics strength after drag-and-drop (px/s²)."
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="GravitySlider" Grid.Column="0"
                                Style="{DynamicResource VsSlider}"
                                Minimum="200" Maximum="2000"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                ValueChanged="GravitySlider_ValueChanged"/>
                        <TextBox x:Name="GravityTextBox" Grid.Column="1"
                                 Style="{DynamicResource VsTextBox}"
                                 Margin="8,0,0,0"
                                 HorizontalContentAlignment="Center"
                                 LostFocus="GravityTextBox_LostFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 BORED THRESHOLD
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Bored Threshold" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="BoredValueLabel"
                                   HorizontalAlignment="Right"
                                   FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                    </Grid>
                    <TextBlock Text="Minutes of inactivity before neglect mode activates."
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="BoredSlider" Grid.Column="0"
                                Style="{DynamicResource VsSlider}"
                                Minimum="1" Maximum="30"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="BoredSlider_ValueChanged"/>
                        <TextBox x:Name="BoredTextBox" Grid.Column="1"
                                 Style="{DynamicResource VsTextBox}"
                                 Margin="8,0,0,0"
                                 HorizontalContentAlignment="Center"
                                 LostFocus="BoredTextBox_LostFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 RUN ON STARTUP
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{DynamicResource StateCard}" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Run on Startup" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Launch Zolak automatically when Windows starts."
                                   FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="StartupCheckBox" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="StartupCheckBox_Changed"
                              Unchecked="StartupCheckBox_Changed"/>
                </Grid>
            </Border>

            <!-- Bottom spacer -->
            <Border Height="20"/>
            <!-- ═══════════════════════════════════════════════════════════
                 FACTORY RESET (DANGER ZONE)
                 ═══════════════════════════════════════════════════════════ -->
            <Border BorderBrush="{DynamicResource DangerColor}" BorderThickness="1" 
                    CornerRadius="4" Padding="16" Margin="0,24,0,12"
                    Opacity="0.8">
                <StackPanel>
                    <TextBlock Text="Danger Zone" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource DangerColor}"/>
                    <TextBlock Text="Revert all configurations, character settings, and custom characters to their factory defaults. This action is irreversible."
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,4,0,12" TextWrapping="Wrap"/>
                    <Button x:Name="ResetBtn" Content="Factory Reset" 
                            Style="{DynamicResource VsButton}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource DangerColor}"
                            Foreground="{DynamicResource DangerColor}"
                            Padding="12,6" HorizontalAlignment="Left"
                            Click="ResetBtn_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
