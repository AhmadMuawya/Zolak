<Window x:Class="WaysToSnooze.Zolak.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zolak Control Panel"
        Width="920" Height="620"
        MinWidth="700" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="8" ClipToBounds="True"
            Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="26"/>  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════
                 TITLE BAR
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <!-- App Icon -->
                        <Image Source="/ZolakIcon.ico" Width="16" Height="16"
                               RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
                        <TextBlock Text="Zolak Control Panel"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window chrome buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinimizeBtn" Style="{DynamicResource TitleBarButton}"
                                Click="MinimizeBtn_Click">
                            <Path Data="M20,14H4V10H20" Width="10" Height="10"
                                  Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="CloseBtn" Style="{DynamicResource CloseButton}"
                                Click="CloseBtn_Click">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                  Width="10" Height="10" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 MAIN CONTENT AREA
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>     <!-- Content Frame -->
                </Grid.ColumnDefinitions>

                <!-- ── Sidebar ──────────────────────────────────────────── -->
                <Border x:Name="SidebarBorder" Grid.Column="0"
                        Width="120" ClipToBounds="True"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="False">

                        <!-- Toggle (top) -->
                        <Button x:Name="SidebarToggleBtn" DockPanel.Dock="Top"
                                Style="{DynamicResource VsGhostButton}"
                                Click="SidebarToggle_Click"
                                HorizontalAlignment="Left" Margin="8,8,0,4"
                                ToolTip="Toggle Sidebar">
                            <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>

                        <!-- Nav Items -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                            <Button x:Name="NavStatesBtn"
                                    Style="{DynamicResource VsNavButton}"
                                    Tag="Active"
                                    Click="NavStates_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M9,17H7V10H9V17M13,17H11V7H13V17M17,17H15V13H17V17M19,19H5V5H19V19.1M19,3H5C3.9,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.9 20.1,3 19,3Z"
                                          Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock x:Name="NavStatesLabel" Text="States"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavSettingsBtn"
                                    Style="{DynamicResource VsNavButton}"
                                    Click="NavSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                          Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock x:Name="NavSettingsLabel" Text="Settings"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Theme Toggle (bottom) -->
                        <Button x:Name="ThemeToggleBtn" DockPanel.Dock="Bottom"
                                Style="{DynamicResource VsGhostButton}"
                                Click="ThemeToggle_Click"
                                HorizontalAlignment="Left" Margin="8,0,0,12"
                                ToolTip="Toggle Theme">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="ThemeIcon"
                                      Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95Z"
                                      Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock x:Name="ThemeLabel" Text="Dark Mode"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- ── Content Area with Dot Canvas ─────────────────────── -->
                <Border Grid.Column="1" Background="{DynamicResource DotCanvasBrush}">
                    <Frame x:Name="ContentFrame"
                           NavigationUIVisibility="Hidden"
                           Margin="0"/>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 STATUS BAR
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="0,0,8,8">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Zolak v0.0.1"
                               Foreground="{DynamicResource TextOnAccent}"
                               FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusMessageText" Grid.Column="1"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextOnAccent}"
                               FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                               VerticalAlignment="Center" Opacity="0"/>
                    <TextBlock x:Name="StatusCharacterText" Grid.Column="2"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextOnAccent}"
                               FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                               VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="StatusCharacter_Click"
                               ToolTip="Click to switch character"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
